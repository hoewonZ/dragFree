{
  "name": "dragfree",
  "version": "0.1.1",
  "private": true,
  "description": "Drag routing desktop app built with Electron",
  "main": "src/main/main.js",
  "type": "module",
  "scripts": {
    "start": "electron .",
    "test": "node --test",
    "build:win": "electron-builder --win portable"
  },
  "devDependencies": {
    "electron": "^37.3.1",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.dragfree.app",
    "productName": "dragFree",
    "asar": true,
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "assets",
        "to": "assets"
      },
      {
        "from": "build/icon.ico",
        "to": "icon.ico"
      }
    ],
    "win": {
      "icon": "build/icon.ico",
      "target": [
        "portable"
      ]
    }
  }
}
